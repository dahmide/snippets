          <div className="card">
            <p className="prose">
              Built for{" "}
              <RotatingText
                texts={ROLES}
                variant="bounce"
                timing={2000}
                paused={paused}
                className="hero-bounce"
              />
              {" "}who refuse to ship mediocre products.
            </p>
            <div className="prose-pause">
              <button
                className={`pause-btn ${paused ? "on" : ""}`}
                onClick={() => setPaused((p) => !p)}
              >
                {paused ? "▶ Resume" : "⏸ Pause"}
              </button>
            </div>
          </div>
        </div>

        {/* ── Bounce standalone ── */}
        <div className="section">
          <p className="section-label">bounce — standalone</p>
          <div className="card">
            <RotatingText
              texts={HERO}
              variant="bounce"
              timing={1800}
              className="hero-bounce"
            />
          </div>
        </div>

        {/* ── Ticker standalone ── */}
        <div className="section">
          <p className="section-label">ticker — standalone</p>
          <div className="card">
            <RotatingText
              texts={["Ship faster.", "Scale smarter.", "Build together.", "Sleep better."]}
              variant="ticker"
              timing={2000}
              className="hero-bounce"
              style={{ color: "#f0ede8", fontStyle: "normal" }}
            />
          </div>
        </div>
      </div>
    </>
  );
}
