        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #0c0c0e; color: #f0ede8; font-family: 'DM Mono', monospace; min-height: 100vh; }

        .page { max-width: 680px; margin: 0 auto; padding: 64px 24px 96px; }
        .eyebrow { font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: #6b6860; margin-bottom: 48px; }
        h1 { font-family: 'Playfair Display', serif; font-size: clamp(2rem,5vw,3rem); font-weight: 400; line-height: 1.15; margin-bottom: 64px; }
        h1 em { color: #c8f04a; font-style: italic; }

        /* ── Section ── */
        .section { margin-bottom: 48px; }
        .section-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #4a4845; margin-bottom: 16px; }

        /* ── Card ── */
        .card { background: #141416; border: 1px solid #1f1f22; border-radius: 6px; padding: 32px; }

        /* ── Input field ── */
        .search-wrap {
          display: flex; align-items: center; gap: 10px;
          background: #0e0e10; border: 1px solid #2a2a2e;
          border-radius: 8px; padding: 14px 16px;
          transition: border-color 0.2s;
        }
        .search-wrap:focus-within { border-color: #3e3e48; }
        .search-icon { color: #3e3e42; flex-shrink: 0; }
        .search-input {
          flex: 1; background: transparent; border: none; outline: none;
          font-family: 'DM Mono', monospace; font-size: 14px; color: #f0ede8;
          min-width: 0;
        }
        .search-input::placeholder { color: transparent; }
        /* The placeholder sits in a sibling span so RotatingText can animate it */
        .search-placeholder {
          position: absolute; pointer-events: none;
          font-family: 'DM Mono', monospace; font-size: 14px;
          color: #3e3e42;
        }
        .search-field-wrap { position: relative; flex: 1; display: flex; align-items: center; }

        /* ── Prose demo ── */
        .prose { font-family: 'Playfair Display', serif; font-size: clamp(1.15rem,3vw,1.5rem); color: #f0ede8; line-height: 1.7; }
        .prose-pause { display: flex; align-items: center; gap: 12px; margin-top: 20px; }

        /* ── Bounce hero ── */
        .hero-bounce { font-family: 'Playfair Display', serif; font-size: clamp(1.6rem,4vw,2.2rem); font-style: italic; color: #c8f04a; }

        .pause-btn {
          background: transparent; border: 1px solid #2a2a2e; color: #5a5855;
          font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.14em;
          text-transform: uppercase; padding: 7px 14px; border-radius: 3px;
          cursor: pointer; transition: all 0.2s; white-space: nowrap;
        }
        .pause-btn:hover { border-color: #3e3e44; color: #9a9895; }
        .pause-btn.on { border-color: #c8f04a44; color: #c8f04a; background: #c8f04a0a; }

        /* ════════════════════════════════════════════
           RotatingText styles
           (production → RotatingText.module.scss)
        ════════════════════════════════════════════ */
        .rt {
          --rt-timing-enter: var(--rt-enter, 400ms);
          --rt-timing-leave: var(--rt-leave, 320ms);
          --rt-ease-enter: cubic-bezier(0.22, 0.68, 0, 1.2);
          --rt-ease-leave: cubic-bezier(0.40, 0.00, 1, 1.0);
          --rt-slide-range: 14px;
          --rt-scale-start: 0.94;

          display: inline-block;
          position: relative;
          /* no overflow:hidden here — bounce variant needs visible overshoot */
        }

        /* Sizer: holds width + height, never visible */
        .rt__sizer {
          display: inline-block;
          visibility: hidden;
          pointer-events: none;
          user-select: none;
        }

        /* Track: floats on top of sizer */
        .rt__track {
          position: absolute;
          left: 0; top: 0;
          width: 100%;
          display: inline-block;
          will-change: transform, opacity;
          /* default → leave transition */
          transition:
            opacity var(--rt-timing-leave) var(--rt-ease-leave),
            transform var(--rt-timing-leave) var(--rt-ease-leave);
        }

        /* ── bounce variant ─────────────────────── */
        .rt[data-variant="bounce"] .rt--ready {
          opacity: 1;
          transform: translateY(0) scale(1);
          transition:
            opacity var(--rt-timing-enter) var(--rt-ease-enter),
            transform var(--rt-timing-enter) var(--rt-ease-enter);
        }
        .rt[data-variant="bounce"] .rt--enter {
          opacity: 0;
          transform: translateY(var(--rt-slide-range)) scale(var(--rt-scale-start));
        }
        .rt[data-variant="bounce"] .rt--leave {
          opacity: 0;
          transform: translateY(calc(var(--rt-slide-range) * -1)) scale(var(--rt-scale-start));
        }

        /* ── ticker variant ─────────────────────── */
        .rt[data-variant="ticker"] {
          overflow: hidden; /* clips the slot */
          vertical-align: bottom;
        }
        .rt[data-variant="ticker"] .rt--ready {
          opacity: 1;
          transform: translateY(0);
          transition:
            opacity var(--rt-timing-enter) ease-out,
            transform var(--rt-timing-enter) cubic-bezier(0.16, 1, 0.3, 1);
        }
        .rt[data-variant="ticker"] .rt--enter {
          opacity: 0;
          transform: translateY(110%);
        }
        .rt[data-variant="ticker"] .rt--leave {
          opacity: 0;
          transform: translateY(-110%);
        }
      `}</style>

