import { useState, useEffect, useRef } from "react";

// ─── clsx ─────────────────────────────────────────────────────────────────────
const clsx = (...args) =>
  args
    .flatMap((a) =>
      typeof a === "string"
        ? a
        : typeof a === "object" && a !== null
        ? Object.entries(a).filter(([, v]) => Boolean(v)).map(([k]) => k)
        : []
    )
    .filter(Boolean)
    .join(" ");

// ─── CSS Module classes ───────────────────────────────────────────────────────
const c = {
  root: "rt",
  track: "rt__track",
  sizer: "rt__sizer",
  ready: "rt--ready",
  leave: "rt--leave",
  enter: "rt--enter",
};

// ─── RotatingText ─────────────────────────────────────────────────────────────
export function RotatingText({
  texts = [],
  paused = false,
  timing = 2500,
  delay = 0,
  variant = "bounce",
  className,
  onTextChange,
  leaveDuration = 320,
  enterDuration = 400,
}) {
  const [index, setIndex] = useState(0);
  const [phase, setPhase] = useState("ready");
  const intervalRef = useRef(null);
  const timeoutsRef = useRef([]);

  useEffect(() => {
    if (onTextChange && texts[index] !== undefined) onTextChange(texts[index]);
  }, [index, texts, onTextChange]);

  useEffect(() => {
    clearInterval(intervalRef.current);
    timeoutsRef.current.forEach((t) => clearTimeout(t));
    timeoutsRef.current = [];

    if (!texts.length || paused || texts.length === 1) return;

    const cycle = () => {
      setPhase("leave");
      const t1 = setTimeout(() => {
        setIndex((i) => (i + 1) % texts.length);
        setPhase("enter");
        const t2 = setTimeout(() => setPhase("ready"), enterDuration);
        timeoutsRef.current.push(t2);
      }, leaveDuration);
      timeoutsRef.current.push(t1);
    };

    // delay is one-time only — interval runs at `timing` after
    const defer = setTimeout(() => {
      cycle();
      intervalRef.current = setInterval(cycle, timing);
    }, delay);
    timeoutsRef.current.push(defer);

    return () => {
      clearInterval(intervalRef.current);
      timeoutsRef.current.forEach((t) => clearTimeout(t));
      timeoutsRef.current = [];
    };
  }, [texts, timing, paused, leaveDuration, enterDuration, delay]);

  return (
    <span
      className={clsx(c.root, className)}
      data-variant={variant}
      style={{
        "--rt-leave": `${leaveDuration}ms`,
        "--rt-enter": `${enterDuration}ms`,
      }}
    >
      {/* Sizer: invisible copy holds the container's width/height */}
      <span className={c.sizer} aria-hidden="true">{texts[index]}</span>
      {/* Track: animated, absolutely positioned over sizer */}
      <span className={clsx(c.track, c[phase])}>{texts[index]}</span>
    </span>
  );
}

// ─── Demo ─────────────────────────────────────────────────────────────────────
const SEARCHES = ["flights to Tokyo", "best noise cancelling headphones", "how to make sourdough", "react animation libraries"];
